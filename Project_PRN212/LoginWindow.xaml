<Window x:Class="Project_PRN212.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project_PRN212"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="800">
    <Canvas>
        <Label Content="Login Page" Canvas.Left="10" Canvas.Top="10" FontSize="35"/>
        <Label Content="Username:" Canvas.Left="51" Canvas.Top="102" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Label Content="Password:" Canvas.Left="51" Canvas.Top="144" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <TextBox Name="txtUsername" Canvas.Left="159" TextWrapping="Wrap" Text="" Canvas.Top="110" Width="241" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <PasswordBox Name="txtPassword" Canvas.Left="159"  Canvas.Top="152" Width="241" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Button Name="btnLogin" Content="Login" Canvas.Left="280" Canvas.Top="207" Height="27" Width="80" FontSize="15" Click="btnLogin_Click"/>
        <Button Name="btnExit" Content="Exit" Canvas.Left="174" Canvas.Top="207" Height="27" Width="80" FontSize="15" HorizontalAlignment="Left" VerticalAlignment="Center" Click="btnExit_Click"/>

    </Canvas>
</Window>
